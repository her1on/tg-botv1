BOT_TOKEN=your_bot_token_from_botfather

# Один владелец:
OWNER_IDS=your_telegram_user_id
# Несколько владельцев:
# OWNER_IDS=111111111,222222222

# PostgreSQL от Supabase (Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

SALON_NAME=Салон красоты
TIMEZONE=Europe/Moscow

# Рабочие дни: 0=Пн, 1=Вт, 2=Ср, 3=Чт, 4=Пт, 5=Сб, 6=Вс
WORKING_DAYS=0,1,2,3,4,5

SERVICES=Стрижка,Окрашивание,Маникюр,Педикюр,Укладка,Уход за лицом
TIME_SLOTS=10:00,11:00,12:00,13:00,14:00,15:00,16:00,17:00,18:00,19:00,20:00
